<!doctype html>
<html lang="{{ site.lang | default: 'en' }}" data-theme="light">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{ site.description | strip_html | normalize_whitespace | escape }}">
    <meta name="theme-color" content="#143f3e">
    <title>{{ page.title | default: site.title | escape }}</title>
    <link rel="canonical" href="{{ site.url }}{{ page.url | relative_url }}">
    <link rel="icon" href="{{ '/assets/img/favicon.svg' | relative_url }}" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Alegreya:ital,wght@0,500;0,600;0,700;1,600&family=Public+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="{{ '/assets/css/personal.css' | relative_url }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ site.title | escape }}">
    <meta property="og:description" content="{{ site.description | strip_html | normalize_whitespace | escape }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url | relative_url }}">
    <meta property="og:image" content="{{ site.url }}{{ '/assets/img/landing-background.webp' | relative_url }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="citation_title" content="The Geographic and Sectoral Impact of Productivity">
    <meta name="citation_author" content="Miguel Del Valle">
    <meta name="citation_author" content="Federico Huneeus">
    <meta name="citation_pdf_url" content="https://www.fedehuneeus.com/s/HdV.pdf">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": {{ site.data.profile.name | jsonify }},
        "jobTitle": {{ site.data.profile.role | jsonify }},
        "email": {{ site.data.profile.emails.first | jsonify }},
        "url": {{ site.url | jsonify }},
        "sameAs": [{{ site.data.profile.linkedin | jsonify }}],
        "alumniOf": {
          "@type": "CollegeOrUniversity",
          "name": "University of Chile"
        },
        "knowsAbout": {{ site.data.profile.research_areas | jsonify }}
      }
    </script>
    {% assign working_papers = site.data.research | where: 'section', 'working-papers' %}
    {% for paper in working_papers %}
      <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "ScholarlyArticle",
          "headline": {{ paper.title | jsonify }},
          "abstract": {{ paper.abstract | jsonify }},
          "author": [
            {% for author in paper.authors %}{"@type":"Person","name":{{ author.name | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}
          ],
          "url": {{ paper.pdf | jsonify }},
          "keywords": {{ paper.keywords | join: ', ' | jsonify }}
        }
      </script>
    {% endfor %}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header" data-site-header>
      <div class="site-header__inner">
        <a class="wordmark" href="#about" aria-label="Miguel Del Valle, home">Miguel Del Valle</a>
        <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-navigation" data-nav-toggle>
          <span class="sr-only">Toggle navigation</span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
        <nav class="site-nav" id="site-navigation" aria-label="Primary navigation" data-site-nav>
          <a href="#about" data-nav-link>About</a>
          <a href="#working-papers" data-nav-link>Working Papers</a>
          <a href="#work-in-progress" data-nav-link>Work in Progress</a>
          <a href="#references" data-nav-link>References</a>
          <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to dark mode" title="Toggle color theme">
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d="M12 3v2m0 14v2M3 12h2m14 0h2M5.64 5.64l1.42 1.42m9.88 9.88 1.42 1.42m0-12.16-1.42 1.42m-9.88 9.88-1.42 1.42M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <section class="intro section" id="about" aria-labelledby="about-title">
        <div class="intro__image" aria-hidden="true"></div>
        <div class="section-shell intro__content">
          <div class="intro__identity">
            <p class="intro__role">{{ site.data.profile.role }}</p>
            <h1 id="about-title">{{ site.data.profile.name }}</h1>
            <p class="intro__lead">{{ site.data.profile.bio }}</p>
            <div class="intro__actions">
              <a class="button button--solid" href="{{ site.data.profile.cv | relative_url }}" target="_blank" rel="noopener"
                >View CV <span aria-hidden="true">↗</span></a
              >
              <a class="text-link" href="mailto:{{ site.data.profile.emails.first }}">Get in touch <span aria-hidden="true">→</span></a>
            </div>
          </div>
          <aside class="intro__aside" aria-label="Profile and research areas">
            <figure class="portrait">
              <img
                src="{{ site.data.profile.portrait | relative_url }}"
                width="800"
                height="800"
                alt="{{ site.data.profile.portrait_alt }}"
                fetchpriority="high"
              >
            </figure>
            <div class="research-areas">
              <h2>Research areas</h2>
              <ul>
                {% for area in site.data.profile.research_areas %}
                  <li>{{ area }}</li>
                {% endfor %}
              </ul>
            </div>
            <div class="contact-links">
              {% for email in site.data.profile.emails %}
                <a href="mailto:{{ email }}">{{ email }}</a>
              {% endfor %}
              <a href="{{ site.data.profile.linkedin }}" target="_blank" rel="noopener" aria-label="Miguel Del Valle on LinkedIn"
                >LinkedIn <span aria-hidden="true">↗</span></a
              >
              {% if site.data.profile.google_scholar %}
                <a href="{{ site.data.profile.google_scholar }}" target="_blank" rel="noopener" aria-label="Miguel Del Valle on Google Scholar"
                  >Google Scholar <span aria-hidden="true">↗</span></a
                >
              {% endif %}
            </div>
          </aside>
        </div>
      </section>

      <section class="section section--research" id="working-papers" aria-labelledby="working-papers-title">
        <div class="section-shell">
          <div class="section-heading">
            <p class="section-heading__index">Research</p>
            <h2 id="working-papers-title">Working Papers</h2>
          </div>
          <div class="paper-list">
            {% assign papers = site.data.research | where: 'section', 'working-papers' | sort: 'order' %}
            {% for paper in papers %}
              <article class="paper" aria-labelledby="{{ paper.id }}-title">
                {% if paper.preview %}
                  <a class="paper__preview" href="{{ paper.pdf }}" target="_blank" rel="noopener" aria-label="Open {{ paper.title }} PDF">
                    <img src="{{ paper.preview | relative_url }}" width="615" height="792" loading="lazy" alt="{{ paper.preview_alt }}">
                  </a>
                {% endif %}
                <div class="paper__body">
                  <div class="paper__meta">
                    <span class="paper__status">{{ paper.status }}</span>
                  </div>
                  <h3 id="{{ paper.id }}-title">{{ paper.title }}</h3>
                  <p class="paper__authors">
                    {% for author in paper.authors %}
                      {% if author.url -%}
                        <a href="{{ author.url }}" target="_blank" rel="noopener">{{ author.name }}</a>
                      {%- else -%}
                        {{- author.name -}}
                      {%- endif -%}
                      {%- unless forloop.last -%}
                        <span aria-hidden="true"> · </span>
                      {%- endunless %}
                    {% endfor %}
                  </p>
                  <details class="paper__abstract" open>
                    <summary>Abstract</summary>
                    <p>{{ paper.abstract }}</p>
                  </details>
                  {% if paper.keywords %}
                    <p class="paper__keywords"><span>Keywords</span> {{ paper.keywords | join: ' · ' }}</p>
                  {% endif %}
                  <div class="paper__links" aria-label="{{ paper.title }} resources">
                    {% if paper.pdf -%}
                      <a href="{{ paper.pdf }}" target="_blank" rel="noopener">Paper <span aria-hidden="true">↗</span></a>
                    {%- endif %}
                    {% if paper.bibtex -%}
                      <a href="{{ paper.bibtex | relative_url }}" download>BibTeX <span aria-hidden="true">↓</span></a>
                    {%- endif %}
                    {% if paper.slides -%}
                      <a href="{{ paper.slides }}" target="_blank" rel="noopener">Slides <span aria-hidden="true">↗</span></a>
                    {%- endif %}
                    {% if paper.appendix -%}
                      <a href="{{ paper.appendix }}" target="_blank" rel="noopener">Appendix <span aria-hidden="true">↗</span></a>
                    {%- endif %}
                    {% if paper.code -%}
                      <a href="{{ paper.code }}" target="_blank" rel="noopener">Code <span aria-hidden="true">↗</span></a>
                    {%- endif %}
                    {% if paper.data -%}
                      <a href="{{ paper.data }}" target="_blank" rel="noopener">Data <span aria-hidden="true">↗</span></a>
                    {%- endif %}
                  </div>
                </div>
              </article>
            {% endfor %}
          </div>
        </div>
      </section>

      <section class="section section--quiet" id="work-in-progress" aria-labelledby="work-in-progress-title">
        <div class="section-shell section-shell--narrow">
          <div class="section-heading">
            <p class="section-heading__index">Research</p>
            <h2 id="work-in-progress-title">Work in Progress</h2>
          </div>
        </div>
      </section>

      <section class="section" id="references" aria-labelledby="references-title">
        <div class="section-shell">
          <div class="section-heading">
            <p class="section-heading__index">Contact</p>
            <h2 id="references-title">References</h2>
          </div>
          <div class="reference-list">
            {% assign references = site.data.references | sort: 'order' %}
            {% for reference in references %}
              <article class="reference">
                <h3>{{ reference.name }}</h3>
                <p>
                  {{ reference.title -}}
                  {%- if reference.department %}, {{ reference.department }}{% endif -%}
                  <br>
                  {{ reference.institution }}
                </p>
                <p class="reference__links">
                  <a href="mailto:{{ reference.email }}">{{ reference.email }}</a
                  ><a href="{{ reference.website }}" target="_blank" rel="noopener">Website <span aria-hidden="true">↗</span></a>
                </p>
              </article>
            {% endfor %}
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="section-shell">
        <span
          >© {{ 'now' | date: '%Y' }}
          {{ site.data.profile.name -}}</span
        ><a href="#about">Back to top ↑</a>
      </div>
    </footer>
    <script src="{{ '/assets/js/personal.js' | relative_url }}" defer></script>
  </body>
</html>
